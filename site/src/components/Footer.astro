---
// Footer component
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <span class="footer-logo">Mouvement solidaire <em>eSPoir</em></span>
        <p class="footer-tagline">Financer. Chercher. Guérir la sclérose en plaques.</p>
      </div>

      <nav class="footer-nav">
        <ul>
          <li><a href="/histoire">Notre histoire</a></li>
          <li><a href="/recherche">La recherche</a></li>
          <li><a href="/evenements">Événements</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/don" class="footer-cta">Faire un don</a></li>
        </ul>
      </nav>

      <div class="footer-contact">
        <p>
          243, boul. Brien, bureau 250<br />
          Repentigny, QC
        </p>
        <p>
          <a href="mailto:info@mouvementespoir.ca">info@mouvementespoir.ca</a>
        </p>
        <div class="footer-social">
          <a href="#" aria-label="Facebook">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>OBNL enregistré au Québec — NEQ 1181 4407 11</p>
      <p>&copy; {new Date().getFullYear()} Mouvement solidaire eSPoir. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-marine);
    color: white;
    padding: var(--space-xl) 0 var(--space-md);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
  }

  .footer-logo em {
    font-style: normal;
    color: var(--color-pale);
  }

  .footer-tagline {
    font-family: var(--font-heading);
    font-style: italic;
    opacity: 0.8;
    margin-top: 0.5rem;
    font-size: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav li {
    margin-bottom: 0.75rem;
  }

  .footer-nav a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: white;
  }

  .footer-cta {
    color: var(--color-hope) !important;
    font-weight: 600;
  }

  .footer-contact {
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .footer-contact p {
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .footer-contact a {
    color: white;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer-social a {
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.2s;
  }

  .footer-social a:hover {
    color: white;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-md);
    display: flex;
    justify-content: space-between;
    font-size: 0.8125rem;
    opacity: 0.6;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
