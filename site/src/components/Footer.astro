---
// Footer component - Modern, minimal
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-cta">
        <h2>Prêt à faire<br/>la différence?</h2>
        <a href="/don" class="btn btn-white">
          Faire un don
          <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>

    <div class="footer-main">
      <div class="footer-brand">
        <span class="footer-logo">eSPoir</span>
        <p class="footer-tagline">
          Financer. Chercher. Guérir<br/>
          la sclérose en plaques.
        </p>
      </div>

      <nav class="footer-nav">
        <span class="footer-nav-title">Navigation</span>
        <ul>
          <li><a href="/histoire">Notre histoire</a></li>
          <li><a href="/recherche">La recherche</a></li>
          <li><a href="/evenements">Événements</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="footer-contact">
        <span class="footer-nav-title">Contact</span>
        <p>
          243, boul. Brien, bureau 250<br />
          Repentigny, QC
        </p>
        <a href="mailto:info@mouvementespoir.ca" class="footer-email">
          info@mouvementespoir.ca
        </a>
      </div>

      <div class="footer-social">
        <span class="footer-nav-title">Suivez-nous</span>
        <div class="footer-social-links">
          <a href="#" aria-label="Facebook">FB</a>
          <a href="#" aria-label="Instagram">IG</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>OBNL enregistré au Québec — NEQ 1181 4407 11</p>
      <p>© {new Date().getFullYear()} Mouvement solidaire eSPoir</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-anthracite);
    color: white;
  }

  .footer-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .footer-top {
    padding: clamp(4rem, 10vw, 8rem) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-cta h2 {
    color: white;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    margin: 0;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    display: block;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.6;
    margin: 0;
  }

  .footer-nav-title {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.4;
    margin-bottom: 1.5rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav li {
    margin-bottom: 0.75rem;
  }

  .footer-nav a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9375rem;
    transition: color 0.3s;
  }

  .footer-nav a:hover {
    color: white;
  }

  .footer-contact p {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.7;
    margin: 0 0 1rem 0;
  }

  .footer-email {
    color: white;
    font-size: 0.9375rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.3s;
  }

  .footer-email:hover {
    border-color: white;
  }

  .footer-social-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-social-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.3s;
  }

  .footer-social-links a:hover {
    color: white;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.8125rem;
    opacity: 0.4;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      margin-bottom: 1rem;
    }
  }

  @media (max-width: 600px) {
    .footer-cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
