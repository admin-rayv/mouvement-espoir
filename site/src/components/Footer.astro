---
// Footer component - Raffiné, sobre
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-cta">
        <h2>Prêt à faire<br/>la différence ?</h2>
        <a href="/don" class="btn btn-secondary btn-light">
          Faire un don
          <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>

    <div class="footer-main">
      <div class="footer-brand">
        <span class="footer-logo">eSPoir</span>
        <p class="footer-tagline">
          Financer. Chercher. Guérir<br/>
          la sclérose en plaques.
        </p>
      </div>

      <nav class="footer-nav">
        <span class="footer-nav-title">Navigation</span>
        <ul>
          <li><a href="/histoire">Notre histoire</a></li>
          <li><a href="/recherche">La recherche</a></li>
          <li><a href="/evenements">Événements</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="footer-contact">
        <span class="footer-nav-title">Contact</span>
        <p>
          243, boul. Brien, bureau 250<br />
          Repentigny, QC
        </p>
        <a href="mailto:info@mouvementespoir.ca" class="footer-email">
          info@mouvementespoir.ca
        </a>
      </div>

      <div class="footer-social">
        <span class="footer-nav-title">Suivez-nous</span>
        <div class="footer-social-links">
          <a href="#" aria-label="Facebook">Facebook</a>
          <a href="#" aria-label="Instagram">Instagram</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>OBNL enregistré au Québec</p>
      <p>© {new Date().getFullYear()} Mouvement solidaire eSPoir</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-noir);
    color: white;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(2rem, 6vw, 5rem);
  }

  .footer-top {
    padding: clamp(5rem, 12vw, 10rem) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 3rem;
  }

  .footer-cta h2 {
    color: white;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 300;
    margin: 0;
    line-height: 1.3;
  }

  .btn-light {
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
  }

  .btn-light:hover {
    border-color: white;
    background: white;
    color: var(--color-noir);
  }

  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    display: block;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.7;
    opacity: 0.5;
    margin: 0;
    font-weight: 300;
  }

  .footer-nav-title {
    display: block;
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.35;
    margin-bottom: 1.75rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav li {
    margin-bottom: 0.875rem;
  }

  .footer-nav a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    font-weight: 300;
    transition: color 0.4s var(--ease-elegant);
  }

  .footer-nav a:hover {
    color: white;
  }

  .footer-contact p {
    font-size: 0.875rem;
    line-height: 1.7;
    opacity: 0.6;
    margin: 0 0 1.25rem 0;
    font-weight: 300;
  }

  .footer-email {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    font-weight: 300;
    transition: opacity 0.4s var(--ease-elegant);
  }

  .footer-email:hover {
    opacity: 0.6;
  }

  .footer-social-links {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-social-links a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    font-weight: 300;
    transition: color 0.4s var(--ease-elegant);
  }

  .footer-social-links a:hover {
    color: white;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.75rem;
    font-weight: 300;
    opacity: 0.35;
    letter-spacing: 0.02em;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .footer-cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
