---
// Header component - Raffiné, discret
---

<header class="header" id="header">
  <div class="header-container">
    <a href="/" class="logo">
      <img src="/images/logo-espoir.png" alt="Mouvement solidaire eSPoir" class="logo-img" />
    </a>

    <nav class="nav" aria-label="Navigation principale">
      <ul class="nav-list">
        <li><a href="/histoire" class="nav-link">Notre histoire</a></li>
        <li><a href="/recherche" class="nav-link">La recherche</a></li>
        <li><a href="/evenements" class="nav-link">Événements</a></li>
        <li><a href="/contact" class="nav-link">Contact</a></li>
      </ul>
    </nav>

    <a href="/don" class="btn btn-primary btn-donate">
      Faire un don
    </a>

    <button class="mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 2rem 0;
    transition: all 0.6s var(--ease-elegant);
  }

  .header.scrolled {
    background: rgba(245, 248, 250, 0.97);
    backdrop-filter: blur(10px);
    padding: 1.25rem 0;
    box-shadow: 0 1px 0 rgba(27, 58, 95, 0.06);
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(2rem, 6vw, 5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 48px;
    width: auto;
    transition: opacity 0.4s var(--ease-elegant);
  }

  .header.scrolled .logo-img {
    height: 40px;
  }

  .logo:hover .logo-img {
    opacity: 0.8;
  }

  .nav-list {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-charcoal);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: opacity 0.4s var(--ease-elegant);
  }

  .header:not(.scrolled) .nav-link {
    color: rgba(255, 255, 255, 0.95);
  }

  .nav-link:hover {
    opacity: 0.6;
  }

  .btn-donate {
    padding: 0.75rem 1.5rem;
    font-size: 0.6875rem;
  }

  .header:not(.scrolled) .btn-donate {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: white;
  }

  .header:not(.scrolled) .btn-donate:hover {
    background: white;
    color: var(--color-noir);
    border-color: white;
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    width: 28px;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-noir);
    transition: all 0.4s var(--ease-elegant);
  }

  .header:not(.scrolled) .mobile-menu-toggle span {
    background: white;
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }

    .btn-donate {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Header scroll effect
  const header = document.getElementById('header');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }, { passive: true });
</script>
