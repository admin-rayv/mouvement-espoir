---
// Header component - Glassmorphism, modern 2025
---

<header class="header" id="header">
  <div class="header-container">
    <a href="/" class="logo">
      <span class="logo-text">eSPoir</span>
    </a>

    <nav class="nav" aria-label="Navigation principale">
      <ul class="nav-list">
        <li><a href="/histoire" class="nav-link">Notre histoire</a></li>
        <li><a href="/recherche" class="nav-link">La recherche</a></li>
        <li><a href="/evenements" class="nav-link">Événements</a></li>
        <li><a href="/contact" class="nav-link">Contact</a></li>
      </ul>
    </nav>

    <a href="/don" class="btn btn-primary btn-donate btn-magnetic">
      Faire un don
      <span class="btn-arrow">→</span>
    </a>

    <button class="mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.5rem 0;
    transition: all 0.5s var(--ease-out-expo);
  }

  /* Glassmorphism on scroll */
  .header.scrolled {
    background: rgba(253, 252, 251, 0.75);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.03),
      0 4px 20px rgba(0, 0, 0, 0.04);
  }

  /* Progress bar */
  .header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 2px;
    background: linear-gradient(90deg, var(--color-hope), var(--color-sky));
    transition: width 0.1s linear;
  }

  .header-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
    position: relative;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-marine);
    letter-spacing: -0.02em;
    transition: transform 0.3s var(--ease-out-expo);
    display: inline-block;
  }

  .logo:hover .logo-text {
    transform: scale(1.05);
  }

  /* Logo color changes based on header state */
  .header:not(.scrolled) .logo-text {
    color: white;
  }

  .nav-list {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-anthracite);
    text-decoration: none;
    transition: color 0.3s, transform 0.3s var(--ease-out-expo);
    position: relative;
    display: inline-block;
  }

  .header:not(.scrolled) .nav-link {
    color: rgba(255, 255, 255, 0.85);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-hope);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .nav-link:hover {
    transform: translateY(-2px);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .header:not(.scrolled) .nav-link::after {
    background: white;
  }

  .btn-donate {
    padding: 0.875rem 1.5rem;
    font-size: 0.8125rem;
    border-radius: 100px;
  }

  .header:not(.scrolled) .btn-donate {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .header:not(.scrolled) .btn-donate:hover {
    background: white;
    color: var(--color-marine);
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    width: 32px;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-anthracite);
    transition: all 0.3s var(--ease-out-expo);
    transform-origin: center;
  }

  .header:not(.scrolled) .mobile-menu-toggle span {
    background: white;
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }

    .btn-donate {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Header scroll effect with progress bar
  const header = document.getElementById('header');

  const updateHeader = () => {
    const scrollY = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (scrollY / docHeight) * 100;

    if (scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    header?.style.setProperty('--scroll-progress', `${progress}%`);
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>
