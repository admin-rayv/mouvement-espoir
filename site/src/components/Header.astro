---
// Header component
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo">
      <span class="logo-text">Mouvement solidaire <em>eSPoir</em></span>
    </a>

    <nav class="nav" aria-label="Navigation principale">
      <ul class="nav-list">
        <li><a href="/histoire">Notre histoire</a></li>
        <li><a href="/recherche">La recherche</a></li>
        <li><a href="/evenements">Événements</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <a href="/don" class="btn btn-primary btn-donate">Faire un don</a>

    <button class="mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(250, 251, 252, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(27, 58, 95, 0.08);
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-marine);
  }

  .logo-text em {
    font-style: normal;
    color: var(--color-ocean);
  }

  .nav-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-list a {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-anthracite);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }

  .nav-list a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-ocean);
    transition: width 0.2s;
  }

  .nav-list a:hover {
    color: var(--color-ocean);
  }

  .nav-list a:hover::after {
    width: 100%;
  }

  .btn-donate {
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-marine);
    transition: all 0.2s;
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }

    .btn-donate {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>
