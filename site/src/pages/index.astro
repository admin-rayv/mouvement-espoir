---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mouvement solidaire eSPoir — Financer. Chercher. Guérir la sclérose en plaques.">
  <Header />

  <main>
    <!-- ========== HERO - Full screen, editorial ========== -->
    <section class="hero">
      <div class="hero-visual">
        <div class="hero-image image-placeholder">
          <span>Photo communauté</span>
        </div>
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="hero-tagline" data-animate data-delay="1">
          <span class="text-label">Mouvement solidaire eSPoir</span>
        </div>

        <h1 data-animate data-delay="2">
          <span class="hero-line">Ensemble,</span>
          <span class="hero-line">finançons</span>
          <span class="hero-line hero-accent">l'espoir</span>
        </h1>

        <div class="hero-bottom" data-animate data-delay="3">
          <p class="hero-description">
            Nous mobilisons la communauté de Lanaudière pour financer
            la recherche sur la sclérose en plaques.
          </p>
          <div class="hero-actions">
            <a href="/don" class="btn btn-white">
              Faire un don
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-scroll">
        <span>Découvrir</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ========== IMPACT - Big statement ========== -->
    <section class="impact">
      <div class="container">
        <div class="impact-content" data-animate>
          <span class="text-huge">100%</span>
          <p class="text-display">
            de votre don finance<br/>
            <em>directement</em> la recherche
          </p>
        </div>
        <div class="impact-detail" data-animate data-delay="2">
          <div class="divider"></div>
          <p class="text-large text-muted">
            Aucun frais administratif. Tout notre travail est bénévole.
            Chaque dollar va aux chercheurs qui travaillent à trouver un remède.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== MISSION - Asymmetric layout ========== -->
    <section class="mission">
      <div class="container">
        <div class="mission-grid">
          <div class="mission-visual" data-animate="slide-left">
            <div class="mission-image-wrapper">
              <div class="mission-image image-placeholder">
                <span>Photo Marie-Carole ou événement</span>
              </div>
              <div class="mission-shape"></div>
            </div>
          </div>

          <div class="mission-content" data-animate="slide-right">
            <span class="text-label">Notre mission</span>
            <h2>Financer.<br/>Chercher.<br/>Guérir.</h2>

            <div class="mission-text">
              <p>
                La sclérose en plaques touche <strong>20 000 Québécois</strong>.
                Dans Lanaudière, ce sont <strong>1 300 personnes</strong> qui vivent avec cette maladie.
              </p>
              <p>
                Le Mouvement solidaire eSPoir organise des événements culturels
                dont tous les profits sont dirigés vers la recherche de pointe.
              </p>
            </div>

            <a href="/histoire" class="link-underline">
              Découvrir notre histoire →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== APPROACH - Three pillars ========== -->
    <section class="approach">
      <div class="container">
        <div class="approach-header" data-animate>
          <span class="text-label">Notre approche</span>
          <h2>Comment nous<br/>faisons la différence</h2>
        </div>

        <div class="approach-items">
          <div class="approach-item" data-animate data-delay="1">
            <span class="approach-number">01</span>
            <h3>Événements culturels</h3>
            <p>
              Spectacles, soupers-bénéfice, activités familiales.
              Des rassemblements qui unissent la communauté.
            </p>
          </div>

          <div class="approach-item" data-animate data-delay="2">
            <span class="approach-number">02</span>
            <h3>Transparence totale</h3>
            <p>
              100% des profits vont à la recherche.
              Zéro frais administratif. Travail 100% bénévole.
            </p>
          </div>

          <div class="approach-item" data-animate data-delay="3">
            <span class="approach-number">03</span>
            <h3>Recherche de pointe</h3>
            <p>
              Nos fonds soutiennent des projets menés par des chercheurs
              reconnus pour leur expertise sur la SP.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== EVENT - Featured ========== -->
    <section class="event">
      <div class="container-wide">
        <div class="event-wrapper" data-animate>
          <div class="event-visual">
            <div class="event-image image-placeholder">
              <span>Photo événement</span>
            </div>
          </div>

          <div class="event-content">
            <span class="text-label">Prochain événement</span>
            <div class="event-date">
              <span class="event-coming">À venir</span>
              <span class="event-year">2026</span>
            </div>
            <h2>Nos événements<br/>arrivent bientôt</h2>
            <p>
              Spectacles, soupers-bénéfice et activités familiales dans Lanaudière.
            </p>
            <a href="#newsletter" class="btn btn-primary">
              Être informé
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== QUOTE ========== -->
    <section class="quote">
      <div class="container">
        <div class="quote-content" data-animate>
          <blockquote>
            "Le Mouvement solidaire eSPoir, c'est l'énergie
            collective canalisée vers un seul objectif:
            <em>la guérison</em>."
          </blockquote>
          <div class="quote-author">
            <div class="quote-avatar image-placeholder">
              <span>Photo</span>
            </div>
            <div class="quote-info">
              <span class="quote-name">Témoignage à venir</span>
              <span class="quote-role">Participant</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== NEWSLETTER ========== -->
    <section class="newsletter" id="newsletter">
      <div class="container">
        <div class="newsletter-wrapper" data-animate>
          <div class="newsletter-content">
            <span class="text-label">Restez informés</span>
            <h2>Joignez-vous<br/>au mouvement</h2>
            <p>
              Recevez les nouvelles de nos événements
              et les avancées de la recherche.
            </p>
          </div>
          <form class="newsletter-form" action="#" method="POST">
            <input
              type="email"
              name="email"
              placeholder="votre@courriel.com"
              required
              aria-label="Adresse courriel"
            />
            <button type="submit" class="btn btn-primary">
              S'inscrire
              <span class="btn-arrow">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
    overflow: hidden;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(27, 58, 95, 0.3) 0%,
      rgba(27, 58, 95, 0.7) 60%,
      rgba(27, 58, 95, 0.95) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(2rem, 8vw, 6rem);
    padding-top: 30vh;
    color: white;
  }

  .hero-tagline {
    margin-bottom: 2rem;
  }

  .hero-tagline .text-label {
    color: rgba(255, 255, 255, 0.7);
  }

  .hero h1 {
    color: white;
    margin-bottom: 3rem;
  }

  .hero-line {
    display: block;
  }

  .hero-accent {
    color: var(--color-hope);
    font-style: italic;
  }

  .hero-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .hero-description {
    max-width: 400px;
    font-size: 1.125rem;
    line-height: 1.7;
    opacity: 0.85;
    margin: 0;
  }

  .hero-scroll {
    position: absolute;
    right: clamp(2rem, 5vw, 4rem);
    bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.5; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* ========== IMPACT ========== */
  .impact {
    padding: clamp(6rem, 15vw, 12rem) 0;
    background: var(--color-white);
  }

  .impact-content {
    margin-bottom: 4rem;
  }

  .impact-content .text-huge {
    margin-bottom: 1rem;
  }

  .impact-content .text-display em {
    font-style: italic;
    color: var(--color-ocean);
  }

  .impact-detail {
    max-width: 600px;
  }

  /* ========== MISSION ========== */
  .mission {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-cream);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(4rem, 8vw, 8rem);
    align-items: center;
  }

  .mission-image-wrapper {
    position: relative;
  }

  .mission-image {
    aspect-ratio: 4/5;
    position: relative;
    z-index: 1;
  }

  .mission-shape {
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 60%;
    height: 60%;
    background: var(--color-ocean);
    opacity: 0.1;
    z-index: 0;
  }

  .mission-content .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .mission-content h2 {
    margin-bottom: 2rem;
  }

  .mission-text {
    margin-bottom: 2rem;
  }

  .mission-text p {
    color: var(--color-gray);
  }

  .mission-text strong {
    color: var(--color-anthracite);
  }

  /* ========== APPROACH ========== */
  .approach {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-white);
  }

  .approach-header {
    margin-bottom: clamp(4rem, 8vw, 6rem);
  }

  .approach-header .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .approach-items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
  }

  .approach-item {
    padding-top: 2rem;
    border-top: 1px solid var(--color-sand);
  }

  .approach-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-ocean);
    margin-bottom: 2rem;
  }

  .approach-item h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .approach-item p {
    color: var(--color-gray);
    margin: 0;
  }

  /* ========== EVENT ========== */
  .event {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--color-marine);
  }

  .container-wide {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .event-wrapper {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
  }

  .event-visual {
    margin: -6rem 0;
  }

  .event-image {
    aspect-ratio: 4/3;
  }

  .event-content {
    color: white;
    padding: 2rem 0;
  }

  .event-content .text-label {
    color: var(--color-sky);
    margin-bottom: 1.5rem;
    display: block;
  }

  .event-date {
    margin-bottom: 1.5rem;
  }

  .event-coming {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .event-year {
    display: block;
    font-size: 1.25rem;
    color: var(--color-sky);
    margin-top: 0.5rem;
  }

  .event-content h2 {
    color: white;
    margin-bottom: 1.5rem;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .event-content p {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
  }

  /* ========== QUOTE ========== */
  .quote {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-sand);
  }

  .quote-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .quote-content blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-marine);
    border: none;
    padding: 0;
    margin: 0 0 3rem 0;
  }

  .quote-content blockquote em {
    font-style: italic;
    color: var(--color-ocean);
  }

  .quote-author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .quote-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
  }

  .quote-info {
    text-align: left;
  }

  .quote-name {
    display: block;
    font-weight: 500;
    color: var(--color-anthracite);
  }

  .quote-role {
    display: block;
    font-size: 0.875rem;
    color: var(--color-gray);
  }

  /* ========== NEWSLETTER ========== */
  .newsletter {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-cream);
  }

  .newsletter-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(4rem, 8vw, 8rem);
    align-items: center;
  }

  .newsletter-content .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .newsletter-content h2 {
    margin-bottom: 1.5rem;
  }

  .newsletter-content p {
    color: var(--color-gray);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .newsletter-form input {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-sand);
    background: white;
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.3s;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-ocean);
  }

  .newsletter-form input::placeholder {
    color: var(--color-gray);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }

    .mission-grid {
      grid-template-columns: 1fr;
    }

    .mission-visual {
      order: -1;
    }

    .mission-image {
      aspect-ratio: 16/9;
    }

    .approach-items {
      grid-template-columns: 1fr;
    }

    .event-wrapper {
      grid-template-columns: 1fr;
    }

    .event-visual {
      margin: 0;
      order: -1;
    }

    .newsletter-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 600px) {
    .hero-scroll {
      display: none;
    }
  }
</style>

<script>
  // Scroll animations
  const animatedElements = document.querySelectorAll('[data-animate]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  });

  animatedElements.forEach(el => observer.observe(el));
</script>
