---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mouvement solidaire eSPoir — Financer. Chercher. Guérir la sclérose en plaques.">
  <Header />

  <!-- Custom cursor -->
  <div class="cursor" id="cursor"></div>
  <div class="cursor-follower" id="cursor-follower"></div>

  <!-- Grain overlay -->
  <div class="grain"></div>

  <main>
    <!-- ========== HERO - Ultra bold, editorial 2025 ========== -->
    <section class="hero">
      <div class="hero-visual">
        <div class="hero-image image-placeholder">
          <span>Photo communauté</span>
        </div>
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="hero-tagline" data-animate data-delay="1">
          <span class="text-label">Mouvement solidaire eSPoir — Lanaudière</span>
        </div>

        <h1 class="hero-title" data-animate data-delay="2">
          <span class="hero-line" data-parallax data-speed="0.1">Ensemble,</span>
          <span class="hero-line" data-parallax data-speed="0.15">finançons</span>
          <span class="hero-line hero-accent" data-parallax data-speed="0.2">l'espoir</span>
        </h1>

        <div class="hero-bottom" data-animate data-delay="3">
          <p class="hero-description">
            Nous mobilisons la communauté pour financer
            la recherche sur la sclérose en plaques.
          </p>
          <div class="hero-actions">
            <a href="/don" class="btn btn-white btn-magnetic btn-glow">
              Faire un don
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-scroll">
        <div class="scroll-indicator">
          <span>Scroll</span>
          <div class="scroll-dot"></div>
        </div>
      </div>
    </section>

    <!-- ========== IMPACT - Massive typography ========== -->
    <section class="impact">
      <div class="container">
        <div class="impact-grid">
          <div class="impact-stat" data-animate="blur">
            <span class="text-massive" data-parallax data-speed="-0.05">100</span>
            <span class="impact-unit">%</span>
          </div>
          <div class="impact-content" data-animate data-delay="2">
            <div class="divider"></div>
            <p class="text-display">
              de votre don finance<br/>
              <em>directement</em> la recherche
            </p>
            <p class="text-large text-muted">
              Aucun frais administratif. Travail 100% bénévole.
              Chaque dollar va aux chercheurs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BENTO GRID - Modern layout ========== -->
    <section class="features">
      <div class="container container-wide">
        <div class="features-header" data-animate>
          <span class="text-label">Notre approche</span>
          <h2>Une mission,<br/>trois piliers</h2>
        </div>

        <div class="bento-grid">
          <div class="bento-item large featured" data-animate data-delay="1">
            <span class="text-label">Transparence</span>
            <h3>Zéro frais<br/>administratif</h3>
            <p>Chaque dollar donné va directement à la recherche. Notre équipe est 100% bénévole.</p>
            <div class="bento-visual">
              <span class="bento-stat">0$</span>
            </div>
          </div>

          <div class="bento-item" data-animate data-delay="2">
            <span class="text-label">Communauté</span>
            <h3>Événements culturels</h3>
            <p>Spectacles, soupers-bénéfice et activités qui unissent Lanaudière.</p>
          </div>

          <div class="bento-item" data-animate data-delay="3">
            <span class="text-label">Science</span>
            <h3>Recherche de pointe</h3>
            <p>Nos fonds soutiennent des projets menés par des experts reconnus.</p>
          </div>

          <div class="bento-item tall" data-animate data-delay="4">
            <div class="bento-image image-placeholder">
              <span>Photo recherche</span>
            </div>
          </div>

          <div class="bento-item large" data-animate data-delay="5">
            <div class="bento-stats">
              <div class="bento-stat-item">
                <span class="bento-stat-number">20 000</span>
                <span class="bento-stat-label">Québécois vivent avec la SP</span>
              </div>
              <div class="bento-stat-item">
                <span class="bento-stat-number">1 300</span>
                <span class="bento-stat-label">Personnes dans Lanaudière</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== MISSION - Asymmetric with parallax ========== -->
    <section class="mission">
      <div class="container">
        <div class="mission-grid">
          <div class="mission-visual" data-animate="slide-left">
            <div class="mission-image-wrapper">
              <div class="mission-image image-placeholder" data-parallax data-speed="0.1">
                <span>Photo Marie-Carole ou événement</span>
              </div>
              <div class="mission-shape blob animated"></div>
            </div>
          </div>

          <div class="mission-content" data-animate="slide-right">
            <span class="text-label">Notre mission</span>
            <h2>Financer.<br/>Chercher.<br/>Guérir.</h2>

            <div class="mission-text">
              <p>
                Le Mouvement solidaire eSPoir canalise l'énergie de toute une communauté
                vers un seul objectif: <strong>trouver un remède</strong> à la sclérose en plaques.
              </p>
            </div>

            <a href="/histoire" class="btn btn-secondary btn-magnetic">
              Découvrir notre histoire
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== HORIZONTAL SCROLL - Testimonials/Partners ========== -->
    <section class="partners">
      <div class="partners-header container" data-animate>
        <span class="text-label">Ils nous soutiennent</span>
        <h2>Ensemble, nous<br/>sommes plus forts</h2>
      </div>

      <div class="horizontal-scroll-wrapper" id="partners-scroll">
        <div class="horizontal-scroll-track">
          <div class="horizontal-scroll-item partner-card" data-animate data-delay="1">
            <div class="partner-logo image-placeholder">
              <span>Logo</span>
            </div>
            <span class="partner-name">Partenaire 1</span>
          </div>

          <div class="horizontal-scroll-item partner-card" data-animate data-delay="2">
            <div class="partner-logo image-placeholder">
              <span>Logo</span>
            </div>
            <span class="partner-name">Partenaire 2</span>
          </div>

          <div class="horizontal-scroll-item partner-card" data-animate data-delay="3">
            <div class="partner-logo image-placeholder">
              <span>Logo</span>
            </div>
            <span class="partner-name">Partenaire 3</span>
          </div>

          <div class="horizontal-scroll-item partner-card" data-animate data-delay="4">
            <div class="partner-logo image-placeholder">
              <span>Logo</span>
            </div>
            <span class="partner-name">Partenaire 4</span>
          </div>

          <div class="horizontal-scroll-item partner-card" data-animate data-delay="5">
            <div class="partner-logo image-placeholder">
              <span>Logo</span>
            </div>
            <span class="partner-name">Partenaire 5</span>
          </div>

          <div class="horizontal-scroll-item partner-card cta">
            <span class="partner-cta">Devenir partenaire →</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== EVENT - Featured ========== -->
    <section class="event">
      <div class="container-wide">
        <div class="event-wrapper" data-animate>
          <div class="event-visual">
            <div class="event-image image-placeholder">
              <span>Photo événement</span>
            </div>
          </div>

          <div class="event-content">
            <span class="text-label">Prochain événement</span>
            <div class="event-date">
              <span class="event-coming">À venir</span>
              <span class="event-year">2026</span>
            </div>
            <h2>Nos événements<br/>arrivent bientôt</h2>
            <p>
              Spectacles, soupers-bénéfice et activités familiales dans Lanaudière.
            </p>
            <a href="#newsletter" class="btn btn-primary btn-magnetic btn-glow">
              Être informé
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== QUOTE - Editorial ========== -->
    <section class="quote">
      <div class="container">
        <div class="quote-content" data-animate="scale">
          <div class="quote-mark">"</div>
          <blockquote>
            Le Mouvement solidaire eSPoir, c'est l'énergie
            collective canalisée vers un seul objectif:
            <em>la guérison</em>.
          </blockquote>
          <div class="quote-author">
            <div class="quote-avatar image-placeholder">
              <span></span>
            </div>
            <div class="quote-info">
              <span class="quote-name">Témoignage à venir</span>
              <span class="quote-role">Participant</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== NEWSLETTER - CTA ========== -->
    <section class="newsletter" id="newsletter">
      <div class="container">
        <div class="newsletter-wrapper glass" data-animate>
          <div class="newsletter-content">
            <span class="text-label">Restez informés</span>
            <h2>Joignez-vous<br/>au mouvement</h2>
            <p>
              Recevez les nouvelles de nos événements
              et les avancées de la recherche.
            </p>
          </div>
          <form class="newsletter-form" action="#" method="POST">
            <input
              type="email"
              name="email"
              placeholder="votre@courriel.com"
              required
              aria-label="Adresse courriel"
            />
            <button type="submit" class="btn btn-primary btn-magnetic">
              S'inscrire
              <span class="btn-arrow">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ========== HERO - Ultra bold ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
    overflow: hidden;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(27, 58, 95, 0.2) 0%,
      rgba(27, 58, 95, 0.5) 50%,
      rgba(27, 58, 95, 0.95) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(2rem, 8vw, 6rem);
    padding-top: 25vh;
    color: white;
  }

  .hero-tagline {
    margin-bottom: 2rem;
  }

  .hero-tagline .text-label {
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-title {
    color: white;
    margin-bottom: 4rem;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .hero-line {
    display: block;
    will-change: transform;
  }

  .hero-accent {
    color: var(--color-hope);
    font-style: italic;
    display: inline-block;
    position: relative;
  }

  .hero-accent::after {
    content: '';
    position: absolute;
    bottom: 0.1em;
    left: 0;
    right: 0;
    height: 0.08em;
    background: var(--color-hope);
    opacity: 0.4;
    transform: skewX(-12deg);
  }

  .hero-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .hero-description {
    max-width: 400px;
    font-size: 1.25rem;
    line-height: 1.7;
    opacity: 0.85;
    margin: 0;
  }

  .hero-scroll {
    position: absolute;
    left: 50%;
    bottom: 3rem;
    transform: translateX(-50%);
    z-index: 2;
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .scroll-dot {
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 50%;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(12px); opacity: 1; }
  }

  /* ========== IMPACT - Massive ========== */
  .impact {
    padding: clamp(8rem, 18vw, 14rem) 0;
    background: var(--color-white);
    overflow: hidden;
  }

  .impact-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(4rem, 8vw, 8rem);
    align-items: center;
  }

  .impact-stat {
    position: relative;
    display: flex;
    align-items: flex-start;
  }

  .impact-stat .text-massive {
    background: linear-gradient(180deg, var(--color-marine) 0%, var(--color-ocean) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .impact-unit {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 500;
    color: var(--color-hope);
    margin-left: 0.5rem;
    margin-top: 1rem;
  }

  .impact-content {
    max-width: 500px;
  }

  .impact-content .text-display em {
    font-style: italic;
    color: var(--color-ocean);
  }

  /* ========== BENTO GRID ========== */
  .features {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-cream);
  }

  .features-header {
    margin-bottom: clamp(4rem, 8vw, 6rem);
  }

  .features-header .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .bento-item h3 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1rem;
    margin-top: 0.5rem;
  }

  .bento-item p {
    color: var(--color-gray);
    margin: 0;
    font-size: 0.9375rem;
  }

  .bento-item.featured p {
    color: rgba(255, 255, 255, 0.7);
  }

  .bento-visual {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
  }

  .bento-stat {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 600;
    opacity: 0.15;
    color: white;
  }

  .bento-image {
    position: absolute;
    inset: 0;
    border-radius: 24px;
  }

  .bento-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    height: 100%;
    justify-content: center;
  }

  .bento-stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bento-stat-number {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 500;
    color: var(--color-marine);
    line-height: 1;
  }

  .bento-stat-label {
    font-size: 0.875rem;
    color: var(--color-gray);
  }

  /* ========== MISSION ========== */
  .mission {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-white);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(4rem, 10vw, 10rem);
    align-items: center;
  }

  .mission-image-wrapper {
    position: relative;
  }

  .mission-image {
    aspect-ratio: 4/5;
    position: relative;
    z-index: 1;
    border-radius: 16px;
    overflow: hidden;
  }

  .mission-shape {
    position: absolute;
    top: -3rem;
    right: -3rem;
    width: 70%;
    height: 70%;
    background: linear-gradient(135deg, var(--color-ocean) 0%, var(--color-sky) 100%);
    opacity: 0.15;
    z-index: 0;
  }

  .mission-content .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .mission-content h2 {
    margin-bottom: 2rem;
  }

  .mission-text {
    margin-bottom: 2.5rem;
  }

  .mission-text p {
    color: var(--color-gray);
    font-size: 1.125rem;
  }

  .mission-text strong {
    color: var(--color-anthracite);
  }

  /* ========== PARTNERS - Horizontal scroll ========== */
  .partners {
    padding: clamp(6rem, 12vw, 10rem) 0 clamp(4rem, 8vw, 6rem);
    background: var(--color-cream);
  }

  .partners-header {
    margin-bottom: 3rem;
  }

  .partners-header .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .partner-card {
    width: 200px;
    height: 200px;
    background: white;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    transition: transform 0.5s var(--ease-out-expo), box-shadow 0.5s var(--ease-out-expo);
  }

  .partner-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);
  }

  .partner-logo {
    width: 80px;
    height: 80px;
    border-radius: 16px;
  }

  .partner-name {
    font-size: 0.875rem;
    color: var(--color-gray);
  }

  .partner-card.cta {
    background: var(--color-marine);
    color: white;
  }

  .partner-cta {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* ========== EVENT ========== */
  .event {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--color-marine);
  }

  .container-wide {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .event-wrapper {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
  }

  .event-visual {
    margin: -6rem 0;
  }

  .event-image {
    aspect-ratio: 4/3;
    border-radius: 16px;
    overflow: hidden;
  }

  .event-content {
    color: white;
    padding: 2rem 0;
  }

  .event-content .text-label {
    color: var(--color-sky);
    margin-bottom: 1.5rem;
    display: block;
  }

  .event-date {
    margin-bottom: 1.5rem;
  }

  .event-coming {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .event-year {
    display: block;
    font-size: 1.25rem;
    color: var(--color-sky);
    margin-top: 0.5rem;
  }

  .event-content h2 {
    color: white;
    margin-bottom: 1.5rem;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .event-content p {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
  }

  /* ========== QUOTE ========== */
  .quote {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-sand);
    overflow: hidden;
  }

  .quote-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .quote-mark {
    font-family: var(--font-heading);
    font-size: clamp(8rem, 20vw, 16rem);
    color: var(--color-ocean);
    opacity: 0.1;
    position: absolute;
    top: -0.3em;
    left: 50%;
    transform: translateX(-50%);
    line-height: 1;
  }

  .quote-content blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-marine);
    border: none;
    padding: 0;
    margin: 0 0 3rem 0;
    position: relative;
    z-index: 1;
  }

  .quote-content blockquote em {
    font-style: italic;
    color: var(--color-hope);
  }

  .quote-author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .quote-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
  }

  .quote-info {
    text-align: left;
  }

  .quote-name {
    display: block;
    font-weight: 500;
    color: var(--color-anthracite);
  }

  .quote-role {
    display: block;
    font-size: 0.875rem;
    color: var(--color-gray);
  }

  /* ========== NEWSLETTER ========== */
  .newsletter {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--color-cream);
  }

  .newsletter-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(4rem, 8vw, 8rem);
    align-items: center;
    padding: clamp(3rem, 6vw, 5rem);
    border-radius: 32px;
  }

  .newsletter-content .text-label {
    margin-bottom: 1.5rem;
    display: block;
  }

  .newsletter-content h2 {
    margin-bottom: 1.5rem;
  }

  .newsletter-content p {
    color: var(--color-gray);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .newsletter-form input {
    padding: 1.5rem 2rem;
    border: none;
    background: white;
    font-family: var(--font-body);
    font-size: 1rem;
    border-radius: 100px;
    transition: box-shadow 0.3s var(--ease-out-expo);
  }

  .newsletter-form input:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(45, 90, 135, 0.15);
  }

  .newsletter-form input::placeholder {
    color: var(--color-gray);
  }

  .newsletter-form .btn {
    border-radius: 100px;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1200px) {
    .impact-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .impact-stat {
      justify-content: center;
    }

    .impact-content {
      max-width: 100%;
    }
  }

  @media (max-width: 900px) {
    .hero-title {
      font-size: clamp(3rem, 14vw, 6rem);
    }

    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }

    .mission-grid {
      grid-template-columns: 1fr;
    }

    .mission-visual {
      order: -1;
    }

    .mission-image {
      aspect-ratio: 16/9;
    }

    .event-wrapper {
      grid-template-columns: 1fr;
    }

    .event-visual {
      margin: 0;
      order: -1;
    }

    .newsletter-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 600px) {
    .hero-scroll {
      display: none;
    }

    .quote-mark {
      font-size: 10rem;
    }
  }
</style>

<script>
  // ========== CUSTOM CURSOR ==========
  const cursor = document.getElementById('cursor');
  const follower = document.getElementById('cursor-follower');
  let mouseX = 0, mouseY = 0;
  let cursorX = 0, cursorY = 0;
  let followerX = 0, followerY = 0;

  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  // Smooth cursor animation
  function animateCursor() {
    // Main cursor - faster
    cursorX += (mouseX - cursorX) * 0.2;
    cursorY += (mouseY - cursorY) * 0.2;

    // Follower - slower
    followerX += (mouseX - followerX) * 0.1;
    followerY += (mouseY - followerY) * 0.1;

    if (cursor) {
      cursor.style.left = `${cursorX}px`;
      cursor.style.top = `${cursorY}px`;
    }

    if (follower) {
      follower.style.left = `${followerX}px`;
      follower.style.top = `${followerY}px`;
    }

    requestAnimationFrame(animateCursor);
  }
  animateCursor();

  // Cursor hover effects
  const hoverElements = document.querySelectorAll('a, button, .btn');
  hoverElements.forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor?.classList.add('active');
      follower?.classList.add('active');
    });
    el.addEventListener('mouseleave', () => {
      cursor?.classList.remove('active');
      follower?.classList.remove('active');
    });
  });

  // ========== MAGNETIC BUTTONS ==========
  const magneticButtons = document.querySelectorAll('.btn-magnetic');
  magneticButtons.forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;

      (btn as HTMLElement).style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
    });

    btn.addEventListener('mouseleave', () => {
      (btn as HTMLElement).style.transform = '';
    });
  });

  // ========== SCROLL ANIMATIONS ==========
  const animatedElements = document.querySelectorAll('[data-animate]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -80px 0px'
  });

  animatedElements.forEach(el => observer.observe(el));

  // ========== PARALLAX ==========
  const parallaxElements = document.querySelectorAll('[data-parallax]');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    parallaxElements.forEach(el => {
      const speed = parseFloat(el.getAttribute('data-speed') || '0.1');
      const rect = el.getBoundingClientRect();
      const centerY = rect.top + rect.height / 2;
      const windowCenter = window.innerHeight / 2;
      const offset = (centerY - windowCenter) * speed;

      (el as HTMLElement).style.transform = `translateY(${offset}px)`;
    });
  }, { passive: true });

  // ========== HORIZONTAL SCROLL DRAG ==========
  const scrollWrapper = document.getElementById('partners-scroll');
  let isDown = false;
  let startX: number;
  let scrollLeft: number;

  if (scrollWrapper) {
    scrollWrapper.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - scrollWrapper.offsetLeft;
      scrollLeft = scrollWrapper.scrollLeft;
    });

    scrollWrapper.addEventListener('mouseleave', () => {
      isDown = false;
    });

    scrollWrapper.addEventListener('mouseup', () => {
      isDown = false;
    });

    scrollWrapper.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - scrollWrapper.offsetLeft;
      const walk = (x - startX) * 2;
      scrollWrapper.scrollLeft = scrollLeft - walk;
    });
  }
</script>
