---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mouvement solidaire eSPoir — Financer. Chercher. Guérir la sclérose en plaques.">
  <Header />

  <main>
    <!-- ========== HERO - Épuré, élégant ========== -->
    <section class="hero">
      <div class="hero-visual">
        <div class="hero-image image-placeholder">
          <span>Photo communauté</span>
        </div>
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="hero-tagline" data-animate data-delay="1">
          <span class="text-label">Mouvement solidaire eSPoir</span>
        </div>

        <h1 data-animate data-delay="2">
          <span class="hero-line">Ensemble,</span>
          <span class="hero-line">finançons</span>
          <span class="hero-line hero-accent">l'espoir</span>
        </h1>

        <div class="hero-bottom" data-animate data-delay="3">
          <p class="hero-description">
            Nous mobilisons la communauté de Lanaudière pour financer
            la recherche sur la sclérose en plaques.
          </p>
          <a href="/don" class="btn btn-white">
            Faire un don
            <span class="btn-arrow">→</span>
          </a>
        </div>
      </div>

      <div class="hero-scroll">
        <span>Défiler</span>
      </div>
    </section>

    <!-- ========== IMPACT - Statement épuré ========== -->
    <section class="impact">
      <div class="container">
        <div class="impact-grid">
          <div class="impact-number" data-animate>
            <span class="text-huge">100%</span>
          </div>
          <div class="impact-content" data-animate data-delay="2">
            <p class="text-display">
              de votre don finance<br/>
              <em>directement</em> la recherche
            </p>
            <div class="divider"></div>
            <p class="text-muted">
              Aucun frais administratif. Tout notre travail est bénévole.
              Chaque dollar va aux chercheurs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== MISSION ========== -->
    <section class="mission">
      <div class="container">
        <div class="mission-grid">
          <div class="mission-visual" data-animate="slide-left">
            <div class="mission-image image-placeholder">
              <span>Photo</span>
            </div>
          </div>

          <div class="mission-content" data-animate="slide-right">
            <span class="text-label">Notre mission</span>
            <h2>Financer.<br/>Chercher.<br/>Guérir.</h2>

            <p>
              La sclérose en plaques touche 20 000 Québécois.
              Dans Lanaudière, 1 300 personnes vivent avec cette maladie.
            </p>
            <p>
              Le Mouvement solidaire eSPoir organise des événements culturels
              dont tous les profits sont dirigés vers la recherche.
            </p>

            <a href="/histoire" class="link-underline">
              Découvrir notre histoire
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== APPROACH ========== -->
    <section class="approach">
      <div class="container">
        <header class="approach-header" data-animate>
          <span class="text-label">Notre approche</span>
          <h2>Comment nous<br/>faisons la différence</h2>
        </header>

        <div class="approach-items">
          <article class="approach-item" data-animate data-delay="1">
            <span class="approach-number">01</span>
            <h3>Événements culturels</h3>
            <p>
              Spectacles, soupers-bénéfice, activités familiales.
              Des rassemblements qui unissent la communauté.
            </p>
          </article>

          <article class="approach-item" data-animate data-delay="2">
            <span class="approach-number">02</span>
            <h3>Transparence totale</h3>
            <p>
              100% des profits vont à la recherche.
              Zéro frais administratif. Travail bénévole.
            </p>
          </article>

          <article class="approach-item" data-animate data-delay="3">
            <span class="approach-number">03</span>
            <h3>Recherche de pointe</h3>
            <p>
              Nos fonds soutiennent des projets menés par des chercheurs
              reconnus pour leur expertise.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ========== EVENT ========== -->
    <section class="event">
      <div class="container">
        <div class="event-wrapper" data-animate>
          <div class="event-content">
            <span class="text-label">Prochain événement</span>
            <h2>Nos événements<br/>arrivent bientôt</h2>
            <p>
              Spectacles, soupers-bénéfice et activités
              familiales dans Lanaudière.
            </p>
            <a href="#newsletter" class="btn btn-secondary">
              Être informé
              <span class="btn-arrow">→</span>
            </a>
          </div>
          <div class="event-visual">
            <div class="event-image image-placeholder">
              <span>Photo événement</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== QUOTE ========== -->
    <section class="quote">
      <div class="container">
        <div class="quote-content" data-animate>
          <blockquote>
            « Le Mouvement solidaire eSPoir, c'est l'énergie
            collective canalisée vers un seul objectif :
            <em>la guérison</em>. »
          </blockquote>
          <footer class="quote-author">
            <span class="quote-name">Témoignage à venir</span>
          </footer>
        </div>
      </div>
    </section>

    <!-- ========== NEWSLETTER ========== -->
    <section class="newsletter" id="newsletter">
      <div class="container">
        <div class="newsletter-wrapper" data-animate>
          <div class="newsletter-content">
            <span class="text-label">Restez informés</span>
            <h2>Joignez-vous<br/>au mouvement</h2>
          </div>
          <form class="newsletter-form" action="#" method="POST">
            <input
              type="email"
              name="email"
              placeholder="votre@courriel.com"
              required
              aria-label="Adresse courriel"
            />
            <button type="submit" class="btn btn-primary">
              S'inscrire
              <span class="btn-arrow">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
    overflow: hidden;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(26, 26, 26, 0.2) 0%,
      rgba(26, 26, 26, 0.5) 50%,
      rgba(26, 26, 26, 0.85) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(3rem, 10vw, 8rem);
    padding-top: 35vh;
    color: white;
    max-width: 900px;
  }

  .hero-tagline {
    margin-bottom: 3rem;
  }

  .hero-tagline .text-label {
    color: rgba(255, 255, 255, 0.6);
  }

  .hero h1 {
    color: white;
    margin-bottom: 4rem;
    font-weight: 300;
  }

  .hero-line {
    display: block;
  }

  .hero-accent {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .hero-description {
    max-width: 380px;
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.75;
    margin: 0;
    font-weight: 300;
  }

  .hero-scroll {
    position: absolute;
    left: clamp(3rem, 10vw, 8rem);
    bottom: 3rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  /* ========== IMPACT ========== */
  .impact {
    padding: clamp(8rem, 18vw, 14rem) 0;
    background: var(--color-white);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(4rem, 10vw, 10rem);
    align-items: baseline;
  }

  .impact-content {
    max-width: 480px;
  }

  .impact-content .text-display em {
    font-style: italic;
  }

  .impact-content .text-muted {
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  /* ========== MISSION ========== */
  .mission {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-cream);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(5rem, 10vw, 10rem);
    align-items: center;
  }

  .mission-image {
    aspect-ratio: 4/5;
  }

  .mission-content .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .mission-content h2 {
    margin-bottom: 3rem;
  }

  .mission-content p {
    color: var(--color-gris);
    margin-bottom: 1.5rem;
  }

  .mission-content .link-underline {
    margin-top: 1rem;
    display: inline-block;
  }

  /* ========== APPROACH ========== */
  .approach {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-white);
  }

  .approach-header {
    margin-bottom: clamp(5rem, 10vw, 8rem);
    max-width: 500px;
  }

  .approach-header .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .approach-items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(3rem, 6vw, 6rem);
  }

  .approach-item {
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-sand);
  }

  .approach-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-gris);
    margin-bottom: 2.5rem;
    letter-spacing: 0.1em;
  }

  .approach-item h3 {
    font-size: 1.375rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .approach-item p {
    color: var(--color-gris);
    margin: 0;
    font-size: 0.9375rem;
  }

  /* ========== EVENT ========== */
  .event {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-ivory);
  }

  .event-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(4rem, 8vw, 8rem);
    align-items: center;
  }

  .event-content .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .event-content h2 {
    margin-bottom: 2rem;
  }

  .event-content p {
    color: var(--color-gris);
    margin-bottom: 2.5rem;
    max-width: 320px;
  }

  .event-image {
    aspect-ratio: 4/3;
  }

  /* ========== QUOTE ========== */
  .quote {
    padding: clamp(10rem, 18vw, 16rem) 0;
    background: var(--color-sand);
  }

  .quote-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .quote-content blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-noir);
    border: none;
    padding: 0;
    margin: 0 0 3rem 0;
    font-style: normal;
  }

  .quote-content blockquote em {
    font-style: italic;
  }

  .quote-author {
    display: block;
  }

  .quote-name {
    font-size: 0.8125rem;
    color: var(--color-gris);
    letter-spacing: 0.05em;
  }

  /* ========== NEWSLETTER ========== */
  .newsletter {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-cream);
  }

  .newsletter-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(4rem, 8vw, 8rem);
    align-items: center;
  }

  .newsletter-content .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .newsletter-content h2 {
    margin-bottom: 0;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .newsletter-form input {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-sand);
    background: white;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    transition: border-color 0.5s var(--ease-elegant);
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-noir);
  }

  .newsletter-form input::placeholder {
    color: var(--color-gris-clair);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1000px) {
    .impact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 900px) {
    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 2.5rem;
    }

    .mission-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .mission-visual {
      order: -1;
    }

    .mission-image {
      aspect-ratio: 16/10;
    }

    .approach-items {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .approach-item {
      padding: 2.5rem 0;
      border-top: none;
      border-bottom: 1px solid var(--color-sand);
    }

    .approach-item:first-child {
      border-top: 1px solid var(--color-sand);
    }

    .event-wrapper {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .event-visual {
      order: -1;
    }

    .newsletter-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 600px) {
    .hero-scroll {
      display: none;
    }
  }
</style>

<script>
  // Scroll animations - plus subtiles
  const animatedElements = document.querySelectorAll('[data-animate]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.15,
    rootMargin: '0px 0px -80px 0px'
  });

  animatedElements.forEach(el => observer.observe(el));
</script>
