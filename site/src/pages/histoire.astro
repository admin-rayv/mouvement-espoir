---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Notre histoire — Mouvement solidaire eSPoir">
  <Header />

  <main>
    <!-- ========== HERO ========== -->
    <section class="hero">
      <div class="hero-visual">
        <div class="hero-image image-placeholder">
          <span>Photo Marie-Carole ou Marche SP</span>
        </div>
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="hero-tagline" data-animate data-delay="1">
          <span class="text-label">Notre histoire</span>
        </div>

        <h1 data-animate data-delay="2">
          <span class="hero-line">Pourquoi le</span>
          <span class="hero-line">Mouvement solidaire</span>
          <span class="hero-line hero-accent">eSPoir?</span>
        </h1>

        <div class="hero-bottom" data-animate data-delay="3">
          <p class="hero-description">
            Une histoire de famille, de solidarité
            et d'espoir face à la sclérose en plaques.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== ORIGINE ========== -->
    <section class="origine">
      <div class="container">
        <div class="origine-content" data-animate>
          <span class="text-label">L'origine</span>
          <h2>Tout a commencé<br/>par une prise de conscience</h2>

          <div class="origine-text">
            <p class="text-lead">
              En 2023, Marie-Carole Daigle est sensibilisée à la réalité
              de la sclérose en plaques.
            </p>
            <p>
              Comme des milliers de Québécois, elle prend conscience
              d'une réalité méconnue : la SP touche <strong>20 000 personnes
              au Québec</strong>, dont <strong>1 300 dans Lanaudière</strong>.
            </p>
            <p>
              Face à ce constat, Marie-Carole choisit l'action.
              Elle participe à la Marche SP avec ses amis.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== PARCOURS ========== -->
    <section class="parcours">
      <div class="container">
        <header class="parcours-header" data-animate>
          <span class="text-label">Le parcours</span>
          <h2>De la marche<br/>au mouvement</h2>
        </header>

        <div class="parcours-timeline">
          <article class="parcours-item" data-animate data-delay="1">
            <span class="parcours-year">2023</span>
            <div class="parcours-content">
              <h3>Première Marche SP</h3>
              <p>
                Marie-Carole et son équipe participent pour la première fois.
                Résultat : <strong>700$</strong> amassés pour la recherche.
              </p>
            </div>
          </article>

          <article class="parcours-item" data-animate data-delay="2">
            <span class="parcours-year">2024</span>
            <div class="parcours-content">
              <h3>L'équipe s'agrandit</h3>
              <p>
                Plus de participants, plus de solidarité.
                L'équipe amasse <strong>2 410$</strong>.
                Un constat émerge : on peut faire plus.
              </p>
            </div>
          </article>

          <article class="parcours-item" data-animate data-delay="3">
            <span class="parcours-year">2025</span>
            <div class="parcours-content">
              <h3>L'objectif est atteint</h3>
              <p>
                <strong>3 000$</strong> récoltés. Mais une question persiste :
                où va réellement l'argent? Combien atteint la recherche?
              </p>
            </div>
          </article>

          <article class="parcours-item parcours-item-highlight" data-animate data-delay="4">
            <span class="parcours-year">Oct. 2025</span>
            <div class="parcours-content">
              <h3>Naissance du Mouvement</h3>
              <p>
                Marie-Carole et Hélène Collette fondent le
                <strong>Mouvement solidaire eSPoir</strong>.
                Mission : <em>100% des dons à la recherche</em>.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ========== VISION ========== -->
    <section class="vision">
      <div class="container">
        <div class="vision-content" data-animate>
          <blockquote>
            « Et si chaque dollar amassé allait
            <em>directement</em> à la recherche? »
          </blockquote>
          <p class="vision-text">
            C'est la question qui a tout changé.
            Le Mouvement solidaire eSPoir est né de cette conviction :
            chaque contribution mérite d'atteindre son but.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== ÉQUIPE ========== -->
    <section class="equipe">
      <div class="container">
        <header class="equipe-header" data-animate>
          <span class="text-label">L'équipe</span>
          <h2>Les fondatrices</h2>
        </header>

        <div class="equipe-grid">
          <article class="membre" data-animate data-delay="1">
            <div class="membre-photo image-placeholder">
              <span>Photo Marie-Carole</span>
            </div>
            <div class="membre-info">
              <h3>Marie-Carole Daigle</h3>
              <span class="membre-role">Fondatrice et présidente</span>
              <p>
                Forte de 40 ans d'expérience en communications,
                Marie-Carole a été journaliste, relationniste et
                bénévole engagée tout au long de sa carrière.
              </p>
              <p>
                Sensibilisée à la réalité de la SP, elle a choisi
                de s'engager pleinement dans cette mission :
                financer la recherche pour offrir l'espoir
                d'un remède à tous ceux qui vivent avec la maladie.
              </p>
            </div>
          </article>

          <article class="membre" data-animate data-delay="2">
            <div class="membre-photo image-placeholder">
              <span>Photo Hélène</span>
            </div>
            <div class="membre-info">
              <h3>Hélène Collette</h3>
              <span class="membre-role">Cofondatrice</span>
              <p>
                Détentrice d'un MBA et spécialiste en plans d'affaires,
                Hélène vit avec la sclérose en plaques depuis 2006.
              </p>
              <p>
                Fondatrice de MonPlanDAffaires.ca, elle apporte
                son expertise stratégique au Mouvement.
                Son expérience personnelle avec la SP
                nourrit sa détermination à soutenir la recherche.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ========== TRANSPARENCE ========== -->
    <section class="transparence">
      <div class="container">
        <div class="transparence-grid">
          <div class="transparence-visual" data-animate>
            <span class="transparence-number">100%</span>
            <span class="transparence-label">va à la recherche</span>
          </div>

          <div class="transparence-content" data-animate data-delay="2">
            <span class="text-label">Transparence</span>
            <h2>Où va<br/>votre argent?</h2>
            <p>
              Tout notre travail est bénévole.
              Chaque dollar amassé finance directement
              des projets de recherche sur la sclérose en plaques.
            </p>
            <p>
              Aucun frais administratif. Aucun salaire.
              Que de l'espoir transformé en action.
            </p>
            <div class="transparence-legal">
              <span>OBNL enregistré au Québec</span>
              <span>NEQ 1181 4407 11</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CTA ========== -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content" data-animate>
          <h2>Rejoignez<br/>le mouvement</h2>
          <p>
            Ensemble, finançons l'espoir de guérison.
          </p>
          <div class="cta-buttons">
            <a href="/don" class="btn btn-primary">
              Faire un don
              <span class="btn-arrow">→</span>
            </a>
            <a href="/evenements" class="link-underline">
              Voir les événements
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
    overflow: hidden;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(27, 58, 95, 0.3) 0%,
      rgba(27, 58, 95, 0.6) 50%,
      rgba(27, 58, 95, 0.9) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(3rem, 10vw, 8rem);
    padding-top: 30vh;
    color: white;
    max-width: 900px;
  }

  .hero-tagline {
    margin-bottom: 2rem;
  }

  .hero-tagline .text-label {
    color: rgba(255, 255, 255, 0.85);
  }

  .hero h1 {
    color: white;
    margin-bottom: 3rem;
    font-weight: 300;
  }

  .hero-line {
    display: block;
  }

  .hero-accent {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-description {
    max-width: 380px;
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.9;
    margin: 0;
    font-weight: 300;
  }

  /* ========== ORIGINE ========== */
  .origine {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-white);
  }

  .origine-content {
    max-width: 680px;
  }

  .origine-content .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .origine-content h2 {
    margin-bottom: 3rem;
  }

  .origine-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .origine-text .text-lead {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-noir);
  }

  .origine-text p {
    color: var(--color-gris);
    margin: 0;
    line-height: 1.8;
  }

  .origine-text strong {
    color: var(--color-noir);
    font-weight: 500;
  }

  /* ========== PARCOURS ========== */
  .parcours {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-cream);
  }

  .parcours-header {
    margin-bottom: clamp(5rem, 10vw, 8rem);
    max-width: 500px;
  }

  .parcours-header .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .parcours-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .parcours-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 3rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-sand);
  }

  .parcours-item:first-child {
    border-top: 1px solid var(--color-sand);
  }

  .parcours-year {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-gris-clair);
    letter-spacing: 0.02em;
  }

  .parcours-content h3 {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .parcours-content p {
    color: var(--color-gris);
    margin: 0;
    max-width: 500px;
    line-height: 1.7;
  }

  .parcours-content strong {
    color: var(--color-noir);
    font-weight: 500;
  }

  .parcours-content em {
    font-style: italic;
  }

  .parcours-item-highlight {
    background: var(--color-ivory);
    margin: 0 -2rem;
    padding: 3rem 2rem;
    border: none;
  }

  .parcours-item-highlight .parcours-year {
    color: var(--color-noir);
    font-weight: 500;
  }

  /* ========== VISION ========== */
  .vision {
    padding: clamp(10rem, 18vw, 16rem) 0;
    background: var(--color-sand);
  }

  .vision-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .vision-content blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-noir);
    border: none;
    padding: 0;
    margin: 0 0 2.5rem 0;
    font-style: normal;
  }

  .vision-content blockquote em {
    font-style: italic;
  }

  .vision-text {
    color: var(--color-gris);
    font-size: 1.0625rem;
    line-height: 1.8;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ========== ÉQUIPE ========== */
  .equipe {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-white);
  }

  .equipe-header {
    margin-bottom: clamp(5rem, 10vw, 6rem);
    max-width: 400px;
  }

  .equipe-header .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .equipe-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(5rem, 10vw, 8rem);
  }

  .membre {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .membre:nth-child(even) {
    direction: rtl;
  }

  .membre:nth-child(even) > * {
    direction: ltr;
  }

  .membre-photo {
    aspect-ratio: 4/5;
  }

  .membre-info h3 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .membre-role {
    display: block;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gris-clair);
    margin-bottom: 2rem;
  }

  .membre-info p {
    color: var(--color-gris);
    margin: 0 0 1.25rem 0;
    line-height: 1.8;
  }

  /* ========== TRANSPARENCE ========== */
  .transparence {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-ivory);
  }

  .transparence-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(5rem, 10vw, 10rem);
    align-items: center;
  }

  .transparence-visual {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .transparence-number {
    font-family: var(--font-heading);
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 300;
    color: var(--color-noir);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .transparence-label {
    font-size: 1.125rem;
    color: var(--color-gris);
    margin-top: 1rem;
    letter-spacing: 0.02em;
  }

  .transparence-content .text-label {
    margin-bottom: 2rem;
    display: block;
  }

  .transparence-content h2 {
    margin-bottom: 2rem;
  }

  .transparence-content p {
    color: var(--color-gris);
    margin: 0 0 1.5rem 0;
    line-height: 1.8;
  }

  .transparence-legal {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-sand);
  }

  .transparence-legal span {
    font-size: 0.875rem;
    color: var(--color-gris-clair);
    letter-spacing: 0.02em;
  }

  /* ========== CTA ========== */
  .cta-section {
    padding: clamp(8rem, 15vw, 12rem) 0;
    background: var(--color-cream);
  }

  .cta-content {
    max-width: 500px;
  }

  .cta-content h2 {
    margin-bottom: 1.5rem;
  }

  .cta-content > p {
    color: var(--color-gris);
    margin-bottom: 3rem;
    font-size: 1.0625rem;
  }

  .cta-buttons {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .parcours-item {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .parcours-item-highlight {
      margin: 0 -1rem;
      padding: 2.5rem 1rem;
    }

    .membre {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .membre:nth-child(even) {
      direction: ltr;
    }

    .membre-photo {
      aspect-ratio: 16/10;
    }

    .transparence-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .transparence-visual {
      align-items: center;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .cta-buttons {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }
</style>

<script>
  // Scroll animations
  const animatedElements = document.querySelectorAll('[data-animate]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.15,
    rootMargin: '0px 0px -80px 0px'
  });

  animatedElements.forEach(el => observer.observe(el));
</script>
